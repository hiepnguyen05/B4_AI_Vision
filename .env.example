# AI Vision Service Environment Variables
# Copy this file to .env and update values

# ======================
# Database Configuration
# ======================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_vision_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ======================
# Spring Configuration
# ======================
SPRING_PROFILES_ACTIVE=dev

# ======================
# External Services URLs
# ======================
# Access Gate Service (B3)
EXTERNAL_SERVICES_ACCESS_GATE_URL=http://localhost:8083/api/access

# Analytics Service (B5)
EXTERNAL_SERVICES_ANALYTICS_URL=http://localhost:8085/api/analytics

# Core Business Service (B6)
EXTERNAL_SERVICES_CORE_URL=http://localhost:8086/api/core

# Notification Service (B7)
EXTERNAL_SERVICES_NOTIFICATION_URL=http://localhost:8087/api/notification

# ======================
# AI Vision Configuration
# ======================
AI_VISION_SIMULATION_ENABLED=true
AI_VISION_SIMULATION_MIN_CONFIDENCE=0.75
AI_VISION_SIMULATION_MAX_CONFIDENCE=0.99

# ======================
# Logging Configuration
# ======================
LOGGING_LEVEL_COM_CAMPUS_SECURITY=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=INFO
LOGGING_LEVEL_ORG_HIBERNATE_SQL=DEBUG

# ======================
# Server Configuration
# ======================
SERVER_PORT=8084
